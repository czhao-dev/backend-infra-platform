{
  "title": "Control Plane",
  "uid": "ctrlplane-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Scheduler Queue Depth",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "ctrlplane_scheduler_queue_depth",
          "legendFormat": "pending jobs",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Worker Health",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "ctrlplane_unhealthy_workers",
          "legendFormat": "unhealthy",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Jobs by Outcome",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(ctrlplane_jobs_succeeded_total[1m])",
          "legendFormat": "succeeded/s",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(ctrlplane_jobs_failed_total[1m])",
          "legendFormat": "failed/s",
          "refId": "B"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(ctrlplane_jobs_dead_letter_total[1m])",
          "legendFormat": "dead-lettered/s",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "Jobs Currently Pending / Running",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "ctrlplane_jobs_pending",
          "legendFormat": "pending",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "ctrlplane_jobs_running",
          "legendFormat": "running",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Scheduler Latency",
      "type": "heatmap",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(ctrlplane_scheduler_latency_seconds_bucket[5m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Reconciler Iterations Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(ctrlplane_reconciler_iterations_total[1m])",
          "legendFormat": "iterations/s",
          "refId": "A"
        }
      ]
    }
  ]
}
